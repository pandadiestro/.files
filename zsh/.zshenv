export EDITOR="nvim"
export VISUAL="nvim"

export PATH="$PATH:/usr/local/go/bin:/sbin:/home/bauer/.local/bin"
export XDG_CONFIG_HOME="/home/bauer/.config"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

export HISTFILE="$ZDOTDIR/.zhistory"
export HISTSIZE=10000                   # Maximum events for internal history
export SAVEHIST=10000                   # Maximum events in history file

export LS_COLORS="di=1;37:ln=1;36:so=1;31:pi=31:ex=1;0:bd=1;34;47:cd=1;30;47:su=30;41:sg=30;46:tw=1;30;42:ow=1;30;43"

